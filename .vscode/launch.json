{
  "compounds": [
    {
      "configurations": [
        "auth emulator",
        "backend",
        "frontend (web)"
      ],
      "name": "auth emulator + backend + frontend (web)",
      "presentation": {
        "group": "1_run",
        "order": 4
      },
      "stopAll": true
    },
    {
      "configurations": [
        "Backend: test",
        "Frontend: tests"
      ],
      "name": "Unit tests (backend + frontend)",
      "presentation": {
        "group": "2_tests",
        "order": 3
      },
      "stopAll": true
    }
  ],
  "configurations": [
    {
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}/frontend",
      "internalConsoleOptions": "neverOpen",
      "name": "auth emulator",
      "presentation": {
        "group": "1_run",
        "order": 0
      },
      "request": "launch",
      "runtimeArgs": [
        "emulators:start",
        "--only",
        "auth"
      ],
      "runtimeExecutable": "firebase",
      "type": "node"
    },
    {
      "args": [
        "8080"
      ],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}/backend",
      "env": {
        "FIREBASE_AUTH_EMULATOR_HOST": "127.0.0.1:9099"
      },
      "mainClass": "social.example.Main",
      "name": "backend",
      "presentation": {
        "group": "1_run",
        "order": 1
      },
      "request": "launch",
      "type": "java",
      "vmArgs": "-Dzookeeper.maxCnxns=200 --enable-native-access=ALL-UNNAMED --sun-misc-unsafe-memory-access=allow"
    },
    {
      "cwd": "${workspaceFolder}/frontend",
      "name": "frontend",
      "presentation": {
        "group": "1_run",
        "order": 2
      },
      "program": "lib/main.dart",
      "request": "launch",
      "type": "dart"
    },
    {
      "cwd": "${workspaceFolder}/frontend",
      "deviceId": "chrome",
      "name": "frontend (web)",
      "presentation": {
        "group": "1_run",
        "order": 3
      },
      "program": "lib/main.dart",
      "request": "launch",
      "toolArgs": [
        "--dart-define=AUTH_EMULATOR_PORT=9099",
        "--dart-define=GRPC_PORT=8080"
      ],
      "type": "dart"
    },
    {
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}/backend",
      "internalConsoleOptions": "neverOpen",
      "name": "Backend: test",
      "presentation": {
        "group": "2_tests",
        "order": 1
      },
      "request": "launch",
      "runtimeArgs": [
        "-lc",
        "./gradlew test --console=plain"
      ],
      "runtimeExecutable": "/bin/bash",
      "type": "node"
    },
    {
      "cwd": "${workspaceFolder}/frontend",
      "name": "Frontend: tests",
      "presentation": {
        "group": "2_tests",
        "order": 2
      },
      "program": "test/",
      "request": "launch",
      "type": "dart"
    },
    {
      "args": [
        "web"
      ],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "internalConsoleOptions": "neverOpen",
      "name": "Patrol E2E (web)",
      "presentation": {
        "group": "3_e2e",
        "order": 1
      },
      "program": "${workspaceFolder}/scripts/patrol_e2e.sh",
      "request": "launch",
      "runtimeExecutable": "/bin/bash",
      "type": "node"
    },
    {
      "args": [
        "web-headless"
      ],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "internalConsoleOptions": "neverOpen",
      "name": "Patrol E2E (web headless)",
      "presentation": {
        "group": "3_e2e",
        "order": 2
      },
      "program": "${workspaceFolder}/scripts/patrol_e2e.sh",
      "request": "launch",
      "runtimeExecutable": "/bin/bash",
      "type": "node"
    },
    {
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "internalConsoleOptions": "neverOpen",
      "name": "Pre-commit (staged)",
      "presentation": {
        "group": "4_hooks",
        "order": 1
      },
      "request": "launch",
      "runtimeArgs": [
        "-lc",
        "lefthook run pre-commit"
      ],
      "runtimeExecutable": "/bin/bash",
      "type": "node"
    },
    {
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "internalConsoleOptions": "neverOpen",
      "name": "Pre-commit (all)",
      "presentation": {
        "group": "4_hooks",
        "order": 2
      },
      "request": "launch",
      "runtimeArgs": [
        "-lc",
        "lefthook run pre-commit --force"
      ],
      "runtimeExecutable": "/bin/bash",
      "type": "node"
    },
    {
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "internalConsoleOptions": "neverOpen",
      "name": "Pre-push (all)",
      "presentation": {
        "group": "4_hooks",
        "order": 3
      },
      "request": "launch",
      "runtimeArgs": [
        "-lc",
        "lefthook run pre-push --force"
      ],
      "runtimeExecutable": "/bin/bash",
      "type": "node"
    }
  ],
  "version": "0.2.0"
}